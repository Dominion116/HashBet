{
  "name": "hashbet-contracts",
  "version": "1.0.0",
  "description": "HashBet Smart Contracts on Celo",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:unit": "hardhat test test/unit/**/*.test.js",
    "test:gas": "REPORT_GAS=true hardhat test",
    "coverage": "hardhat coverage",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:testnet": "hardhat run scripts/deploy.js --network celoSepolia",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network celoSepolia",
    "deploy:mainnet": "hardhat run scripts/deploy.js --network celoMainnet",
    "verify": "hardhat verify",
    "export:abi": "cp artifacts/contracts/HashBet.sol/HashBet.json ../hashbet-sdk/src/contract/abi.json"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^3.0.0",
    "hardhat": "^2.14.0",
    "hardhat-gas-reporter": "^1.0.10",
    "solidity-coverage": "^0.8.14",
    "solhint": "^4.1.1",
    "ethers": "^6.0.0",
    "dotenv": "^17.4.2"
  }
}
