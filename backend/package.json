{
  "name": "hashbet-api",
  "version": "1.0.0",
  "description": "HashBet Backend API",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:unit": "jest --testPathPattern='test/unit'",
    "test:integration": "jest --testPathPattern='test/integration'",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src test --ext .js",
    "format": "prettier --write 'src/**/*.js' 'test/**/*.js'",
    "migrate": "node src/scripts/migrate.js",
    "db:check": "node src/scripts/check-db.js",
    "db:backfill:chain": "node src/scripts/backfill-chain-bets.js",
    "db:reset": "node src/scripts/reset-db.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "clarityxo-ai": "^0.1.0",
    "clarityxo-sdk": "^0.4.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "ethers": "^6.0.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.7.1",
    "predictstack-sdk": "^0.1.2",
    "predictstackjssdk": "^0.1.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^2.0.20",
    "prettier": "^3.3.3",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/**/*.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov"
    ],
    "testTimeout": 15000
  }
}
